{
  "expo": {
    "name": "PingPoint Driver",
    "slug": "pingpoint-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pingpoint",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pingpoint.driver",
      "associatedDomains": [
        "applinks:6770693b-fc9a-4c02-9b92-87ade92b7c79-00-3kcz61rsl8wvd.worf.replit.dev",
        "applinks:*.replit.dev"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PingPoint Driver needs your location to track deliveries and share your position with dispatchers.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "PingPoint Driver needs background location access to continue tracking while you're driving."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a1f",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.pingpoint.driver",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "*.replit.dev",
              "pathPrefix": "/driver"
            },
            {
              "scheme": "https",
              "host": "6770693b-fc9a-4c02-9b92-87ade92b7c79-00-3kcz61rsl8wvd.worf.replit.dev",
              "pathPrefix": "/driver"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "pingpoint",
              "host": "*",
              "pathPrefix": "/driver"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a1f",
          "dark": {
            "backgroundColor": "#0a0a1f"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PingPoint Driver needs your location to track deliveries.",
          "locationAlwaysPermission": "PingPoint Driver needs background location to track your route while driving.",
          "locationWhenInUsePermission": "PingPoint Driver needs your location to share your position."
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
