{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_AGENTOS_INTERNAL_KEY": "pingpoint-internal-2024"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_AGENTOS_INTERNAL_KEY": "pingpoint-internal-2024"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_AGENTOS_INTERNAL_KEY": "pingpoint-internal-2024"
      }
    }
  },
  "submit": {
    "production": {}
  }
}